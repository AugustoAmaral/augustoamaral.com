---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/globals.css';
import '../styles/fonts.css';
import type { Locale } from '../i18n/ui';
import { useTranslation } from '../i18n/ui';

interface Props {
  title: string;
  description: string;
  locale: Locale;
  pathname: string;
  activeNav?: string;
}

const { title, description, locale, pathname, activeNav } = Astro.props;
const t = useTranslation(locale);

const canonicalUrl = `https://augustoamaral.com${pathname}`;
const enUrl = locale === 'pt'
  ? 'https://augustoamaral.com' + (pathname.replace(/^\/pt/, '') || '/')
  : canonicalUrl;
const ptUrl = locale === 'en'
  ? 'https://augustoamaral.com/pt' + (pathname === '/' ? '/' : pathname)
  : canonicalUrl;
---

<!doctype html>
<html lang={locale === 'pt' ? 'pt-BR' : 'en'} dir="ltr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="pt-BR" href={ptUrl} />
  </head>
  <body>
    <a href="#main" class="skip-link">{t('skipToContent')}</a>
    <Header locale={locale} pathname={pathname} activeNav={activeNav} />
    <main id="main">
      <slot />
    </main>
    <Footer locale={locale} />
  </body>
</html>
