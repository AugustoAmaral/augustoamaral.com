---
import LanguageToggle from './LanguageToggle.astro';
import { useTranslation } from '../i18n/ui';
import type { Locale } from '../i18n/ui';

interface Props {
  locale: Locale;
  pathname: string;
  activeNav?: string;
}

const { locale, pathname, activeNav } = Astro.props;
const t = useTranslation(locale);

const logoHref = locale === 'pt' ? '/pt/' : '/';

interface NavItem {
  key: string;
  label: string;
  href: string;
}

const navItems: NavItem[] = [
  { key: 'experiences', label: t('nav.experiences'), href: locale === 'pt' ? '/pt/experiences' : '/experiences' },
  { key: 'shelf',       label: t('nav.shelf'),       href: locale === 'pt' ? '/pt/shelf' : '/shelf' },
  { key: 'channel',     label: t('nav.channel'),     href: locale === 'pt' ? '/pt/channel' : '/channel' },
  { key: 'liz',         label: t('nav.liz'),         href: locale === 'pt' ? '/pt/liz' : '/liz' },
  { key: 'principles',  label: t('nav.principles'),  href: locale === 'pt' ? '/pt/principles' : '/principles' },
];
---

<header class="site-header">
  <a href={logoHref} class="logo" aria-label="augustoamaral.com — home">
    <span class="logo-box" aria-hidden="true">A</span>
    <span class="logo-text">augustoamaral.com</span>
  </a>

  <div class="header-right">
    <nav class="site-nav" aria-label="Main navigation">
      {navItems.map(item => (
        <a
          href={item.href}
          class:list={['nav-link', { active: activeNav === item.key }]}
          aria-current={activeNav === item.key ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>
    <LanguageToggle locale={locale} pathname={pathname} />
  </div>
</header>

<style>
  .site-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 32px 40px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
  }

  .logo-box {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border: 1px solid var(--fg-primary);
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1;
    flex-shrink: 0;
  }

  .logo-text {
    font-family: var(--font-mono);
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--fg-primary);
  }

  .header-right {
    display: flex;
    align-items: baseline;
    gap: 24px;
  }

  .site-nav {
    display: flex;
    align-items: baseline;
    gap: 24px;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 12px;
    text-decoration: none;
    color: var(--fg-muted);
    transition: color 0.15s;
  }

  .nav-link.active {
    color: var(--fg-primary);
  }

  .nav-link:hover:not(.active) {
    color: var(--fg-primary);
  }

  @media (max-width: 720px) {
    .site-header {
      padding: 20px 24px;
      flex-direction: column;
      gap: 16px;
      align-items: flex-start;
    }

    .header-right {
      flex-wrap: wrap;
      gap: 16px;
    }

    .site-nav {
      flex-wrap: wrap;
      gap: 12px;
    }
  }
</style>
